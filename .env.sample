# Copy this file to .env and fill in real secret values before starting the server.
# Placeholders like {self.api_keys['openai']} cannot be resolved by the script — replace them manually.

OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>
XAI_API_KEY=<YOUR_XAI_API_KEY>
GROQ_API_KEY=<YOUR_GROQ_API_KEY>
SERVER_PORT=8002
LOCAL_IP=127.0.0.1
MQTT_BROKER_IP=192.168.1.100
KAFKA_SERVERS=localhost:9092
DEBUG=False
MAX_CLIENTS=10

# Rename to .env and edit values when ready.
